{
  "name": "lfi_dashboard",
  "version": "1.0.0",
  "description": "LFI Sovereign Dashboard",
  "main": "index.js",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "mobile-lint": "bash scripts/mobile-lint.sh",
    "mobile-smoke": "echo 'Paste scripts/mobile-smoke.js into DevTools console at mobile emulation sizes — this is a runtime harness, not a CLI test.' && exit 0",
    "audit": "npm run mobile-lint",
    "prebuild": "npm run audit",
    "ci": "npm run audit && npm run build"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-virtuoso": "^4.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "vite": "^4.4.0"
  }
}
